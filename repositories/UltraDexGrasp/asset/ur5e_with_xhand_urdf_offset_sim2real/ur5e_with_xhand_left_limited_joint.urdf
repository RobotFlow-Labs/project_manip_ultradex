<?xml version="1.0" ?>
<robot name="ur5e_robot">

    <!-- 创建中间链接用于连接各关节 -->
    <link name="base_link_for_offset"/>
    <link name="pos_x_link"/>
    <link name="pos_y_link"/>
    <link name="pos_z_link"/>
    <link name="rot_x_link"/>
    <link name="rot_y_link"/>
    <!-- X方向平移关节 -->
    <joint name="pos_x_joint" type="prismatic">
      <parent link="base_link_for_offset"/>
      <child link="pos_x_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-10" upper="10" effort="100" velocity="1"/>
    </joint>
    <!-- Y方向平移关节 -->
    <joint name="pos_y_joint" type="prismatic">
      <parent link="pos_x_link"/>
      <child link="pos_y_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-10" upper="10" effort="100" velocity="1"/>
    </joint>
    <!-- Z方向平移关节 -->
    <joint name="pos_z_joint" type="prismatic">
      <parent link="pos_y_link"/>
      <child link="pos_z_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-10" upper="10" effort="100" velocity="1"/>
    </joint>
    <!-- X轴旋转关节 -->
    <joint name="rot_x_joint" type="revolute">
      <parent link="pos_z_link"/>
      <child link="rot_x_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="1 0 0"/>
      <limit lower="-6.28" upper="6.28" effort="100" velocity="1"/>
    </joint>
    <!-- Y轴旋转关节 -->
    <joint name="rot_y_joint" type="revolute">
      <parent link="rot_x_link"/>
      <child link="rot_y_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-6.28" upper="6.28" effort="100" velocity="1"/>
    </joint>
    <!-- Z轴旋转关节 -->
    <joint name="rot_z_joint" type="revolute">
      <parent link="rot_y_link"/>
      <child link="base_link"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.28" upper="6.28" effort="100" velocity="1"/>
    </joint>


  <link name="base_link"/>
  <link name="base_offset_link"/>
  <link name="base_link_inertia">
    <visual>
      <origin rpy="0 0 3.141592653589793" xyz="0 0 0"/>
      <geometry>
        <mesh filename="meshes/visual/base.dae"/>
      </geometry>
      <material name="LightGrey">
        <color rgba="0.7 0.7 0.7 1.0"/>
