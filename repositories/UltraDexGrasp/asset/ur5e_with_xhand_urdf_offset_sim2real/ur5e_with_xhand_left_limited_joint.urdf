  </link>
  <joint name="connector_joint" type="fixed">
    <parent link="wrist_3_link"/>
    <child link="connector"/>
    <origin rpy="0 1.57079 0" xyz="0 0 0.0305"/>
  </joint>

  <joint name="arm_hand_joint" type="fixed">
