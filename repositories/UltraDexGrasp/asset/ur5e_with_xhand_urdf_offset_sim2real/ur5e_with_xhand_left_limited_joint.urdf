    <collision>
      <origin rpy="1.5707963267948966 0 -1.5707963267948966" xyz="0 0 0.007"/>
      <geometry>
        <mesh filename="meshes/collision/forearm.stl"/>
      </geometry>
    </collision>
    <inertial>
